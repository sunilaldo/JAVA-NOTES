*{
            padding:0;
            margin:0;
            box-sizing: border-box;
        }
        body{
            background-color:radial-gradient(rgb(255, 2, 247),rgb(255, 221, 0),rgb(212, 5, 5));
            /* background-image:radial-gradient(rgb(255, 2, 247),rgb(255, 221, 0),rgb(212, 5, 5)); */
        }
         .box{
            height:500px;
            width:500px;
            border:2px solid blue;
            background-color: blueviolet;
            background-size: 500px 500px;   
            background-image:radial-gradient(rgb(255, 48, 2),rgb(255, 221, 0),rgb(212, 5, 5));
            /* background-image:linear-gradient(rgb(2, 15, 255),rgb(0, 128, 255),rgb(191, 212, 5)); */

        } 